# Supabase設定
# SupabaseプロジェクトのURLとAnon Keyを設定
# https://app.supabase.com でプロジェクトを作成後、Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe設定
# Stripeダッシュボード（https://dashboard.stripe.com）から取得
# テストモードと本番モードで異なるキーを使用
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Stripeサブスクリプション設定
# 1. Stripeダッシュボード > Products > Add product で商品を作成
# 2. Price IDをコピー（例: price_xxxxx）
STRIPE_PRICE_ID=your_stripe_price_id

# Stripe Webhook設定
# 1. Stripeダッシュボード > Developers > Webhooks > Add endpoint
# 2. URL: https://your-domain.com/api/stripe/webhook
# 3. Events: checkout.session.completed, customer.subscription.deleted
# 4. Signing secretをコピー（whsec_で始まる文字列）
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Anthropic Claude API設定
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=your_anthropic_api_key

# Next.js設定
# 本番環境のURL（Vercelデプロイ時に自動設定される場合あり）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 情報収集バッチ処理用APIキー
# Twitter API v2
# https://developer.twitter.com/en/portal/dashboard で取得
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# YouTube Data API v3
# https://console.cloud.google.com/apis/credentials で取得
YOUTUBE_API_KEY=your_youtube_api_key

# Vercel Cron認証
# バッチ処理のセキュリティのため、ランダムな文字列を設定
# 例: openssl rand -hex 32
CRON_SECRET=your_cron_secret_key
